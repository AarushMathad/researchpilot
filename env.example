# === Required ===
GEMINI_API_KEY=

# === Model ===
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.1

# === Search ===
SEMANTIC_SCHOLAR_API_KEY=           # optional — raises rate limit 10x
MAX_PAPERS_PER_QUERY=5
MAX_SEARCH_QUERIES=3

# === Pipeline ===
TOP_K_PAPERS=8
SUMMARIZER_BATCH_SIZE=3
REFLECTION_THRESHOLD=0.65
MIN_CORPUS_SIZE=4                   # warn user if fewer papers found after search

# === Ranking weights (must sum to 1.0) ===
# Increase RECENCY / decrease CITATION for emerging fields
RANK_WEIGHT_SEMANTIC=0.40
RANK_WEIGHT_CITATION=0.30
RANK_WEIGHT_RECENCY=0.20
RANK_WEIGHT_VENUE=0.10

# === Embeddings ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./research_pilot.db

# === SSE ===
SSE_QUEUE_TTL_SECONDS=600           # clear completed session queues after 10 min
